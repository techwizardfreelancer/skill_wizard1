{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "regions": ["iad1"],
  "framework": "vite",
  "env": {
    "VITE_API_BASE_URL": "https://backend-production-a518.up.railway.app/api",
    "VITE_SOCKET_URL": "https://backend-production-a518.up.railway.app"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
