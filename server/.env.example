# === MongoDB Atlas Configuration ===
# Get this from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/skill_wizard
MONGO_URI=mongodb+srv://skill_wizard_user:your_password_here@cluster0.mongodb.net/skill_wizard

# === Server Configuration ===
NODE_ENV=production
PORT=5000

# === Frontend URL (for CORS in production) ===
# Replace with your actual Vercel frontend URL
FRONTEND_URL=https://skill-wizard.vercel.app

# === Optional: Redis URL (if using job queues) ===
# REDIS_URL=redis://localhost:6379

# === Optional: Docker Image Prefix ===
# DOCKER_IMAGE_PREFIX=skillwizardsandbox

# === Optional: Logging ===
# LOG_LEVEL=info
